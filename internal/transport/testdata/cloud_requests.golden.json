[
  {
    "transport": "handy_cloud_rest",
    "operation": "stroke_window",
    "method": "PUT",
    "path": "slider/stroke",
    "auth": {
      "application_id": "app-public-id",
      "connection_key_set": true,
      "firmware_major": 4,
      "api_major": 3
    },
    "body": {
      "min": 0.1,
      "max": 0.9
    }
  },
  {
    "transport": "handy_cloud_rest",
    "operation": "hsp_setup",
    "method": "PUT",
    "path": "hsp/setup",
    "auth": {
      "application_id": "app-public-id",
      "connection_key_set": true,
      "firmware_major": 4,
      "api_major": 3
    },
    "body": {
      "stream_id": 1
    }
  },
  {
    "transport": "handy_cloud_rest",
    "operation": "hsp_add",
    "method": "PUT",
    "path": "hsp/add",
    "auth": {
      "application_id": "app-public-id",
      "connection_key_set": true,
      "firmware_major": 4,
      "api_major": 3
    },
    "body": {
      "points": [
        {
          "x": 0,
          "t": 0
        },
        {
          "x": 50,
          "t": 125
        },
        {
          "x": 100,
          "t": 250
        }
      ],
      "flush": true,
      "tail_point_stream_index": 3
    }
  },
  {
    "transport": "handy_cloud_rest",
    "operation": "hsp_play",
    "method": "PUT",
    "path": "hsp/play",
    "auth": {
      "application_id": "app-public-id",
      "connection_key_set": true,
      "firmware_major": 4,
      "api_major": 3
    },
    "body": {
      "start_time": 0,
      "playback_rate": 1,
      "pause_on_starving": true,
      "loop": false
    }
  },
  {
    "transport": "handy_cloud_rest",
    "operation": "stop",
    "method": "PUT",
    "path": "hsp/stop",
    "auth": {
      "application_id": "app-public-id",
      "connection_key_set": true,
      "firmware_major": 4,
      "api_major": 3
    },
    "body": {}
  }
]
